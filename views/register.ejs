<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar - Endcore System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.6)), url('https://endfield.gryphline.com/images/bg-placeholder.jpg') center/cover no-repeat;
            height: 100vh; display: flex; align-items: center; justify-content: center; overflow: hidden;
        }

        .register-modal {
            background-color: #2d2d2d;
            width: 100%; max-width: 480px;
            border-radius: 8px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.6);
            color: #fff; position: relative;
        }

        .modal-header-custom {
            display: flex; align-items: center; justify-content: center;
            padding: 25px 20px 15px; position: relative;
        }
        .modal-header-custom h2 {
            font-size: 1.4rem; font-weight: 900; letter-spacing: 1px; margin: 0;
        }
        .btn-back-custom {
            position: absolute; left: 20px;
            background: #444; color: #fff; border: none;
            width: 35px; height: 35px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: 0.3s; text-decoration: none;
        }
        .btn-back-custom:hover { background: #666; color: #fff; }

        .modal-body-custom { padding: 20px 30px 40px; }
        
        .input-group-custom {
            background: #4a4a4a; border-radius: 4px;
            display: flex; align-items: center; padding: 0 15px;
            margin-bottom: 15px; transition: 0.3s;
        }
        .input-group-custom:focus-within { background: #555; }
        .input-group-custom input {
            background: transparent; border: none; color: #fff;
            padding: 16px 5px; width: 100%; outline: none; font-size: 0.95rem;
        }
        .input-group-custom input::placeholder { color: #999; }
        .input-group-custom i { color: #aaa; cursor: pointer; }

        .checkbox-group {
            display: flex; align-items: flex-start; gap: 10px;
            margin-bottom: 15px; font-size: 0.85rem; color: #ccc;
        }
        .checkbox-group input[type="checkbox"] {
            margin-top: 4px; width: 16px; height: 16px;
            accent-color: #8bb14a; cursor: pointer;
        }
        .checkbox-group a { color: #fff; font-weight: bold; text-decoration: none; }
        .checkbox-group a:hover { text-decoration: underline; }

        .btn-register {
            background-color: #7b9c3a; color: #000;
            width: 100%; border: none; padding: 16px; border-radius: 4px;
            font-weight: 900; font-size: 1.1rem; cursor: pointer;
            position: relative; transition: 0.3s; margin-top: 10px;
        }
        .btn-register:hover { background-color: #8bb14a; }
        .btn-register::after {
            content: ''; position: absolute; bottom: 0; right: 0;
            border-bottom: 15px solid #000; border-left: 15px solid transparent;
        }
    </style>
</head>
<body>

    <div class="register-modal">
        <div class="modal-header-custom">
            <a href="/login" class="btn-back-custom"><i class="fas fa-arrow-left"></i></a>
            <h2>DAFTAR</h2>
        </div>
        
        <div class="modal-body-custom">
            <form action="/register" method="POST">
                <div class="input-group-custom">
                    <input type="text" name="username" placeholder="Masukkan username" required>
                </div>
                <div class="input-group-custom">
                    <input type="email" name="email" placeholder="Masukkan alamat email" required>
                </div>
                <div class="input-group-custom">
                    <input type="password" name="password" id="passInput" placeholder="Masukkan kata sandi" required>
                    <i class="fas fa-eye-slash toggle-pass" data-target="passInput"></i>
                </div>
                <div class="input-group-custom">
                    <!-- Note: Konfirmasi sandi biasanya dicek via JS atau dibelakang layar -->
                    <input type="password" id="confirmPassInput" placeholder="Masukkan ulang kata sandi" required>
                    <i class="fas fa-eye-slash toggle-pass" data-target="confirmPassInput"></i>
                </div>
                
                <div class="checkbox-group mt-4">
                    <input type="checkbox" required id="tos">
                    <label for="tos">Setujui <a href="#">Ketentuan Layanan</a> dan <a href="#">Kebijakan Privasi</a></label>
                </div>
                <div class="checkbox-group">
                    <input type="checkbox" id="newsletter">
                    <label for="newsletter">Berlangganan pembaruan dan penawaran (opsional)</label>
                </div>
                
                <button type="submit" class="btn-register">Daftar</button>
            </form>
        </div>
    </div>

    <script>
        // Logika hide/show password
        document.querySelectorAll('.toggle-pass').forEach(icon => {
            icon.addEventListener('click', function() {
                const targetId = this.getAttribute('data-target');
                const input = document.getElementById(targetId);
                const type = input.getAttribute('type') === 'password' ? 'text' : 'password';
                input.setAttribute('type', type);
                this.classList.toggle('fa-eye');
                this.classList.toggle('fa-eye-slash');
            });
        });
    </script>
</body>
</html>