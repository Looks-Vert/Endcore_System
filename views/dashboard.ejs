                                    <option value="QRIS" <%= pkg.metode_pembayaran === 'QRIS' ? 'selected' : '' %>>QRIS</option>
                                    <option value="Bank" <%= pkg.metode_pembayaran === 'Bank' ? 'selected' : '' %>>Bank Transfer</option>
                                    <option value="E-Wallet" <%= pkg.metode_pembayaran === 'E-Wallet' ? 'selected' : '' %>>E-Wallet</option>
                                </select>
                            </div>
                            <button type="submit" class="btn-submit" style="background:#ffb300; color:#000;">Simpan Perubahan</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    <% }) } %>

    <!-- Data Chart (Tersembunyi) -->
    <div id="chartData" 
         data-labels='<%- locals.chars ? JSON.stringify(chars.map(c => c.nama)) : "[]" %>' 
         data-likes='<%- locals.chars ? JSON.stringify(chars.map(c => c.total_likes)) : "[]" %>' 
         style="display: none;">
    </div>

    <!-- Script Utama -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function switchTab(title, tabId, btnElement) {
            document.getElementById('pageTitle').innerText = title;
            document.querySelectorAll('.admin-tab').forEach(tab => tab.classList.remove('active'));
            document.querySelectorAll('.menu-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            btnElement.classList.add('active');
        }

        // Render Grafik Likes
        const ctx = document.getElementById('likeChart').getContext('2d');
        const chartElement = document.getElementById('chartData');
        const chartLabels = JSON.parse(chartElement.getAttribute('data-labels'));
        const chartLikes = JSON.parse(chartElement.getAttribute('data-likes'));

        new Chart(ctx, {
            type: 'line', 
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Jumlah Interaksi (Likes)',
                    data: chartLikes,
                    backgroundColor: 'rgba(40, 167, 69, 0.1)', 
                    borderColor: '#28a745', 
                    borderWidth: 2,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: '#28a745',
                    pointRadius: 4,
                    fill: true,
                    tension: 0.4 
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { 
                    y: { beginAtZero: true, grid: { color: '#eee', drawBorder: false } }, 
                    x: { grid: { display: false, drawBorder: false } } 
                },
                plugins: { legend: { display: false } } 
            }
        });
    </script>
</body>
</html>